# Shared secret expected in request header: x-trigger-token
TRIGGER_TOKEN=replace-with-strong-secret

# Azure target for the Container Apps Job
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_RESOURCE_GROUP=your-resource-group
AZURE_CONTAINERAPPS_JOB_NAME=your-worker-job

# Optional if job template has multiple containers
AZURE_CONTAINERAPPS_JOB_CONTAINER_NAME=worker

# Optional (defaults to JOB_PAYLOAD)
PAYLOAD_ENV_VAR_NAME=JOB_PAYLOAD

# Optional (defaults to 5)
AZURE_MAX_ACTIVE_EXECUTIONS=5

# Required: backend callback URL invoked after container start succeeds.
TRIGGER_BACKEND_CALLBACK_URL=

# Worker env vars should be configured directly on the container definition
# (ACA Job template) as static env/secrets. Trigger injects only JOB_PAYLOAD.
