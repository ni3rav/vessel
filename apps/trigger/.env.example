# Shared secret expected in request header: x-trigger-token
TRIGGER_TOKEN=replace-with-strong-secret

# Azure target for the existing ACI container group
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_RESOURCE_GROUP=your-resource-group
AZURE_CONTAINER_GROUP=your-container-group

# Optional if container group has multiple containers
AZURE_CONTAINER_NAME=worker

# Optional (defaults to JOB_PAYLOAD)
PAYLOAD_ENV_VAR_NAME=JOB_PAYLOAD

# Required: backend callback URL invoked after container start succeeds.
TRIGGER_BACKEND_CALLBACK_URL=

# Worker env passthrough: trigger injects these into target worker container.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
SOURCE_BASE_URL=
WORKER_CALLBACK_URL=
WORKER_SECRET=
OUTPUT_DIR=
TEMP_DIR=
FFMPEG_PATH=
FFPROBE_PATH=
HLS_SEGMENT_DURATION=
LOG_LEVEL=

# Optional fallback for private registry auth during ACI createOrUpdate.
# Needed when ARM GET omits image registry password.
AZURE_IMAGE_REGISTRY_SERVER=
AZURE_IMAGE_REGISTRY_USERNAME=
AZURE_IMAGE_REGISTRY_PASSWORD=
