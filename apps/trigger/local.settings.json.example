{
  "IsEncrypted": false,
  "Values": {
    "FUNCTIONS_WORKER_RUNTIME": "node",
    "AzureWebJobsStorage": "UseDevelopmentStorage=true",
    "TRIGGER_TOKEN": "replace-with-strong-secret",
    "AZURE_SUBSCRIPTION_ID": "00000000-0000-0000-0000-000000000000",
    "AZURE_RESOURCE_GROUP": "your-resource-group",
    "AZURE_CONTAINERAPPS_JOB_NAME": "your-worker-job",
    "AZURE_CONTAINERAPPS_JOB_CONTAINER_NAME": "worker",
    "PAYLOAD_ENV_VAR_NAME": "JOB_PAYLOAD",
    "AZURE_MAX_ACTIVE_EXECUTIONS": "5",
    "TRIGGER_BACKEND_CALLBACK_URL": "https://your-backend.example.com/internal/jobs/started",
    "FUNCTIONS_NODE_BLOCK_ON_ENTRY_POINT_ERROR": "true"
  }
}
