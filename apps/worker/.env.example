# REQUIRED (ACI): R2 credentials + bucket for source download and output upload
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=your-r2-bucket-name

# REQUIRED (ACI): Public base URL used to download source files by payload key
# Combined as: R2_PUBLIC_BASE_URL/<key>
R2_PUBLIC_BASE_URL=public-base-url-of-your-r2-bucket

# REQUIRED (ACI): Source base URL used to download source files by payload key
SOURCE_BASE_URL=source-base-url-of-your-r2-bucket

# REQUIRED (callback): Backend callback endpoint and shared worker secret
WORKER_CALLBACK_URL=https://your-backend.example.com/api/internal/worker-callback
WORKER_SECRET=replace-with-worker-secret

# OPTIONAL: Only required if you do not provide job JSON over stdin.
# In Azure Container Instance, setting JOB_PAYLOAD is usually easiest.
# Example:
# JOB_PAYLOAD={"id":"test-001","key":"uploads/user_abc/test-001.mp3","filename":"test.mp3","userid":"user_abc","jobSecret":"generated-per-job-secret"}
JOB_PAYLOAD=

# OPTIONAL (defaults shown): Directories for output HLS files and temporary working files
OUTPUT_DIR=/data/output
TEMP_DIR=/data/temp

# OPTIONAL (defaults shown): Paths to FFmpeg binaries (defaults to system PATH)
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# OPTIONAL (default shown): Duration of each HLS segment in seconds
HLS_SEGMENT_DURATION=6

# OPTIONAL (default shown): Log verbosity: debug | info | warn | error
LOG_LEVEL=info
