# R2 credentials + bucket for direct upload
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=your-r2-bucket-name

# Public base URL used to download source files by payload key
# Combined as: R2_PUBLIC_BASE_URL/<key>
R2_PUBLIC_BASE_URL=public-base-url-of-your-r2-bucket

# Directories for output HLS files and temporary working files
OUTPUT_DIR=/data/output
TEMP_DIR=/data/temp

# Paths to FFmpeg binaries (defaults to system PATH)
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Duration of each HLS segment in seconds
HLS_SEGMENT_DURATION=6

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info
