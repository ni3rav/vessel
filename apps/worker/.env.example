# Base URL used to construct the source audio download URL
# Combined with the job payload `key` as: SOURCE_BASE_URL/<key>
SOURCE_BASE_URL=https://pub-xxxx.r2.dev

# Directories for output HLS files and temporary working files
OUTPUT_DIR=/data/output
TEMP_DIR=/data/temp

# Paths to FFmpeg binaries (defaults to system PATH)
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Duration of each HLS segment in seconds
HLS_SEGMENT_DURATION=6

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info
